{
  "framework": "vite",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://mithra-backend-0f0r.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://mithra-backend-0f0r.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
