{
  "framework": "vite",
  "installCommand": "cd \"front end\" && bun install",
  "buildCommand": "cd \"front end\" && bun run build",
  "outputDirectory": "front end/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://raksha-mvp-backend.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://raksha-mvp-backend.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
